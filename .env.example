# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY=

# SUPABASE_URL: Your Supabase Project URL
SUPABASE_URL=
VITE_SUPABASE_URL=

# SUPABASE_ANON_KEY: Your Supabase Project Anon Key
SUPABASE_ANON_KEY=
VITE_SUPABASE_ANON_KEY=

# SUPABASE_SERVICE_ROLE_KEY: Required for backend operations (Storage, DB management)
SUPABASE_SERVICE_ROLE_KEY=

# STORAGE_BUCKET: The name of the storage bucket for task attachments
STORAGE_BUCKET=task-attachments

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3001" # Local development URL

# FRONTEND_URL: Used by backend CORS
FRONTEND_URL=http://localhost:5173 # Vite frontend URL

# VITE_API_BASE_URL: Backend API URL used by frontend
# Local dev: để trống (Vite proxy /api → localhost:3001)
# Production: đặt URL Vercel backend project
VITE_API_BASE_URL=