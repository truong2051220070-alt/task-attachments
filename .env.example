# Supabase — dùng chung cho backend
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase — expose cho frontend (Vite sẽ đọc các biến VITE_*)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Storage bucket cho file đính kèm (mặc định: task-attachments)
STORAGE_BUCKET=task-attachments

# CORS: URL frontend được phép truy cập backend (mặc định: http://localhost:5173)
FRONTEND_URL=http://localhost:5173

# API Base URL cho frontend — để trống khi dev (dùng Vite proxy)
# Khi deploy production, đặt URL Vercel của backend, ví dụ: https://task-backend.vercel.app
VITE_API_BASE_URL=
